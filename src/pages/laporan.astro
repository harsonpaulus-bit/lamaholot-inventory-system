---
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/shared/Badge.astro';
import { createSSRClient } from '../lib/supabase';

const token = Astro.cookies.get('sb-access-token')?.value;
const supabase = createSSRClient(token);
import '../styles/print.css';

// Ambil query param di SSR
const kategoriId = Astro.url.searchParams.get('kategori') || '';
const kondisi = Astro.url.searchParams.get('kondisi') || '';

let barangList: any[] = [];
let kategoriList: any[] = [];
let stats = { total: 0, baik: 0, rusakRingan: 0, rusakBerat: 0 };
let error = null;

try {
  let query = supabase.from('barang').select('*, kategori(nama_kategori)').order('kategori_id');
  if (kategoriId) query = query.eq('kategori_id', kategoriId);
  if (kondisi) query = query.eq('kondisi', kondisi);

  const [
    { data: barangData },
    { data: kategoriData }
  ] = await Promise.all([
    query,
    supabase.from('kategori').select('*').order('nama_kategori')
  ]);
  
  barangList = barangData || [];
  kategoriList = kategoriData || [];
  
  // Calculate stats from the filtered list (or all if no filter)
  stats.total = barangList.length;
  barangList.forEach(b => {
    if (b.kondisi === 'Baik') stats.baik++;
    if (b.kondisi === 'Rusak Ringan') stats.rusakRingan++;
    if (b.kondisi === 'Rusak Berat') stats.rusakBerat++;
  });
} catch (e: any) {
  // Dummy fallback
  error = e.message;
}

const currentDate = new Date().toLocaleDateString('id-ID', { month: 'long', year: 'numeric' });
const printDate = new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title="Laporan Inventaris">
  <!-- Print Header (Hidden on screen) -->
  <div class="print-header hidden">
    <h2 style="font-size: 24px; margin-bottom: 5px; font-weight: bold;">SD LAMAHOLOT</h2>
    <p style="margin: 0;">Jl. Jagung Raya-Bojong Indah, Rawa Buaya, Jakarta Barat</p>
    <p style="margin: 0;">Telp: 021-58356813 | Email: sdslamaholot11@gmail.com</p>
    <h3 style="margin-top: 20px; font-size: 18px; font-weight: bold;">LAPORAN INVENTARIS BARANG</h3>
    <p style="margin: 5px 0;">Periode: {currentDate}</p>
  </div>

  <!-- Screen Content -->
  <!-- Screen Content -->
  <div class="mb-8 animate-fade-in flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 no-print">
    <div>
      <h1 class="text-3xl font-bold text-surface-900 tracking-tight">Laporan Inventaris</h1>
      <p class="text-surface-500 mt-1">Pratinjau laporan sebelum dicetak</p>
    </div>
    <button id="btn-print" onclick="window.print()" class="btn-primary !bg-[#354ae6] hover:!bg-[#283593] !shadow-sm focus:ring-4 focus:ring-primary-500/20">
      <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
      <span>Cetak Laporan</span>
    </button>
  </div>

  <!-- Filters (Hidden on Print) -->
  <!-- Filters (Hidden on Print) -->
  <div class="glass-card p-4 mb-6 flex flex-col md:flex-row gap-4 relative z-20 no-print">
    <div class="flex items-center text-surface-500 mr-2">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
      <span class="font-bold text-sm tracking-wide">Filter Laporan:</span>
    </div>
    
    <form action="/laporan" method="GET" class="flex flex-col md:flex-row gap-4 flex-1">
      <div class="flex-1 relative">
         <select name="kategori" class="w-full pl-4 pr-10 py-2.5 bg-surface-50 border border-surface-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition-colors appearance-none text-sm font-medium text-surface-600 cursor-pointer">
           <option value="">Semua Kategori</option>
           {kategoriList.map(k => <option value={k.id} selected={k.id === kategoriId}>{k.nama_kategori}</option>)}
         </select>
         <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-surface-400">
           <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
         </div>
      </div>

      <div class="flex-1 relative">
         <select name="kondisi" class="w-full pl-4 pr-10 py-2.5 bg-surface-50 border border-surface-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition-colors appearance-none text-sm font-medium text-surface-600 cursor-pointer">
           <option value="">Semua Kondisi</option>
           <option value="Baik" selected={kondisi === 'Baik'}>Baik</option>
           <option value="Rusak Ringan" selected={kondisi === 'Rusak Ringan'}>Rusak Ringan</option>
           <option value="Rusak Berat" selected={kondisi === 'Rusak Berat'}>Rusak Berat</option>
         </select>
         <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-surface-400">
           <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
         </div>
      </div>

      <div class="flex gap-2">
         <button type="submit" class="bg-surface-900 hover:bg-black text-white px-6 py-2.5 rounded-xl font-bold text-sm transition-colors shadow-sm focus:ring-4 focus:ring-surface-900/20">
           Terapkan
         </button>
         {(kategoriId || kondisi) && (
           <a href="/laporan" class="px-5 py-2.5 bg-white border border-surface-200 text-surface-600 hover:text-surface-900 hover:bg-surface-50 font-bold text-sm rounded-xl flex items-center justify-center transition-colors">Reset</a>
         )}
      </div>
    </form>
  </div>

  <!-- Summary Statistics -->
  <div class="glass-card mb-6 p-6 no-print">
    <h3 class="text-sm font-bold text-surface-900 mb-6 uppercase tracking-wider">Ringkasan Filter</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="p-4 bg-surface-50 rounded-xl relative overflow-hidden">
        <p class="text-xs font-semibold text-surface-500 mb-1">Total Barang</p>
        <p class="text-3xl font-extrabold text-surface-900">{stats.total}</p>
      </div>
      <div class="p-4 bg-green-50/50 rounded-xl relative overflow-hidden">
        <p class="text-xs font-semibold text-green-700 mb-1">Kondisi Baik</p>
        <p class="text-3xl font-extrabold text-green-600">{stats.baik} <span class="text-sm font-bold text-green-500/70 ml-1">({stats.total ? Math.round(stats.baik/stats.total*100) : 0}%)</span></p>
      </div>
      <div class="p-4 bg-yellow-50/50 rounded-xl relative overflow-hidden">
        <p class="text-xs font-semibold text-yellow-700 mb-1">Rusak Ringan</p>
        <p class="text-3xl font-extrabold text-yellow-600">{stats.rusakRingan} <span class="text-sm font-bold text-yellow-500/70 ml-1">({stats.total ? Math.round(stats.rusakRingan/stats.total*100) : 0}%)</span></p>
      </div>
      <div class="p-4 bg-red-50/50 rounded-xl relative overflow-hidden">
        <p class="text-xs font-semibold text-red-700 mb-1">Rusak Berat</p>
        <p class="text-3xl font-extrabold text-red-600">{stats.rusakBerat} <span class="text-sm font-bold text-red-500/70 ml-1">({stats.total ? Math.round(stats.rusakBerat/stats.total*100) : 0}%)</span></p>
      </div>
    </div>
  </div>

  <!-- Data Table -->
  <div class="glass-card overflow-hidden">
    <table class="min-w-full divide-y divide-surface-200" id="print-table">
      <thead class="bg-surface-50/50">
        <tr>
          <th scope="col" class="px-6 py-4 text-left pl-6 w-12 text-xs font-bold text-surface-500 uppercase tracking-wider">No</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-surface-500 uppercase tracking-wider">Nama Barang</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-surface-500 uppercase tracking-wider">Kategori</th>
          <th scope="col" class="px-6 py-4 text-center text-xs font-bold text-surface-500 uppercase tracking-wider">Jml</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-surface-500 uppercase tracking-wider">Kondisi</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-surface-500 uppercase tracking-wider">Lokasi</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-surface-100">
        {barangList.map((item, index) => (
          <tr class="hover:bg-surface-50 transition-colors">
            <td class="px-6 py-3 font-semibold text-surface-800 text-sm pl-6">{index + 1}</td>
            <td class="px-6 py-3 font-semibold text-surface-900 text-sm break-words">{item.nama_barang}</td>
            <td class="px-6 py-3 text-sm font-medium text-surface-500">{item.kategori?.nama_kategori || '-'}</td>
            <td class="px-6 py-3 text-center">
              <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold bg-surface-100 text-surface-700 font-mono">
                {item.jumlah}
              </span>
            </td>
            <td class="px-6 py-3">
              <div class="no-print">
                <Badge kondisi={item.kondisi} />
              </div>
              <div class="print-only hidden font-semibold text-sm">
                {item.kondisi}
              </div>
            </td>
            <td class="px-6 py-3 text-sm font-medium text-surface-500">{item.lokasi || '-'}</td>
          </tr>
        ))}
        {barangList.length === 0 && (
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-surface-500 font-medium">Tidak ada data ditemukan untuk kriteria filter ini.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>

  <!-- Print Footer (Hidden on screen) -->
  <div class="print-footer hidden text-sm relative mt-16 pt-8 break-inside-avoid">
    <div style="position: absolute; left: 0;">
      <p style="margin: 0; color: #666;">Dicetak pada: {printDate}</p>
    </div>
    
    <div style="flex: 1; text-align: right; float: right;">
      <p style="margin-bottom: 60px;">Mengetahui,<br>Kepala Sekolah</p>
      <p style="margin: 0;">_______________________</p>
      <p style="margin: 0;">NIP. </p>
    </div>
    
    <div style="flex: 1; text-align: left; float: left; margin-left: 20px;">
        <p style="margin-bottom: 60px;">Ttd,<br>Admin/Staf TU</p>
        <p style="margin: 0;">_______________________</p>
    </div>
    <div style="clear: both;"></div>
  </div>
</MainLayout>
