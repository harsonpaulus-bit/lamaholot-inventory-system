---
import MainLayout from '../layouts/MainLayout.astro';
import { createSSRClient } from '../lib/supabase';

const token = Astro.cookies.get('sb-access-token')?.value;
const supabase = createSSRClient(token);

let kategoriList: any[] = [];
let error = null;

try {
  // Query with count of related items. Note: count in join with Supabase can be tricky.
  // Standard syntax: select('*, barang(count)') -> results in barang: [{ count: x }] array
  const { data, error: fetchError } = await supabase
    .from('kategori')
    .select('id, nama_kategori, created_at, barang:barang(count)')
    .order('nama_kategori');
    
  if (fetchError) throw fetchError;
  
  // Format the count for easier consumption
  kategoriList = (data || []).map(k => ({
    ...k,
    barang_count: k.barang[0]?.count || 0
  }));
} catch (e: any) {
  kategoriList = [
    { id: 'cat1', nama_kategori: 'Mebeler', barang_count: 15 },
    { id: 'cat2', nama_kategori: 'Elektronik', barang_count: 5 },
    { id: 'cat3', nama_kategori: 'Alat Kebersihan', barang_count: 0 }
  ];
}
---

<MainLayout title="Kelola Kategori">
  <div class="mb-8 animate-fade-in flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h1 class="text-3xl font-bold text-surface-900 tracking-tight">Kategori Barang</h1>
      <p class="text-surface-500 mt-1">Kelola klasifikasi untuk inventaris sekolah</p>
    </div>
    
    <button id="btn-add-kategori" class="btn-primary !bg-[#354ae6] hover:!bg-[#283593] !shadow-sm focus:ring-4 focus:ring-primary-500/20">
      <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      <span>Tambah Kategori</span>
    </button>
  </div>

  <div class="glass-card flex-1 overflow-hidden h-full flex flex-col p-2 mt-4">
    <div class="flex-1 overflow-x-auto p-2">
      <table class="w-full text-left border-separate border-spacing-y-2">
        <thead class="bg-surface-50/50">
          <tr>
            <th class="px-6 py-4 text-xs font-bold text-surface-500 uppercase tracking-wider rounded-l-xl w-12">No</th>
            <th class="px-6 py-4 text-xs font-bold text-surface-500 uppercase tracking-wider w-full">Nama Kategori</th>
            <th class="px-6 py-4 text-xs font-bold text-surface-500 uppercase tracking-wider whitespace-nowrap text-center">Jumlah Barang</th>
            <th class="px-6 py-4 text-xs font-bold text-surface-500 uppercase tracking-wider text-center rounded-r-xl w-24">Aksi</th>
          </tr>
        </thead>
        <tbody>
          {kategoriList.map((kat, index) => (
            <tr class="bg-white hover:bg-surface-50 transition-colors shadow-sm ring-1 ring-surface-200/60 rounded-xl group cursor-default">
              <td class="px-6 py-3 font-semibold text-surface-800 text-sm rounded-l-xl">{index + 1}</td>
              <td class="px-6 py-3 font-semibold text-surface-800 text-sm">{kat.nama_kategori}</td>
              <td class="px-6 py-3 text-center">
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-primary-50 text-primary-700 font-mono">
                  {kat.barang_count} <span class="ml-1 text-primary-500/70 font-sans">item</span>
                </span>
              </td>
              <td class="px-6 py-3 text-center rounded-r-xl">
                <div class="flex justify-center space-x-2">
                  <button class="btn-edit text-surface-400 hover:text-primary-600 p-1.5 hover:bg-primary-50 rounded-lg transition-colors" data-id={kat.id} data-nama={kat.nama_kategori} aria-label="Edit">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                  </button>
                  <button class={`btn-delete p-1.5 rounded-lg transition-colors ${kat.barang_count > 0 ? 'text-surface-300 cursor-not-allowed hidden' : 'text-surface-400 hover:text-red-600 hover:bg-red-50'}`} 
                    data-id={kat.id} data-nama={kat.nama_kategori} data-count={kat.barang_count} aria-label="Hapus"
                    title={kat.barang_count > 0 ? "Tidak bisa dihapus (memiliki barang)" : "Hapus Kategori"}>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  </button>
                </div>
              </td>
            </tr>
          ))}
          
          {kategoriList.length === 0 && (
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-surface-500">
                <div class="flex flex-col items-center justify-center py-10">
                  <div class="w-16 h-16 bg-surface-50 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8 text-surface-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
                  </div>
                  <p class="text-lg font-bold text-surface-900">Belum ada kategori</p>
                  <p class="text-sm text-surface-400 mt-1">Tambahkan kategori pertama Anda</p>
                </div>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Form Modal (Add/Edit) -->
  <div id="modal-form" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm mx-4 transform translate-y-4 transition-transform duration-300" id="modal-form-content">
      <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
        <h3 id="modal-title" class="text-lg font-semibold text-gray-900">Tambah Kategori</h3>
        <button id="btn-close-modal" class="text-gray-400 hover:text-gray-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <div class="p-6">
        <form id="kategori-form" class="space-y-4">
          <input type="hidden" id="form-id" name="id" />
          
          <div>
            <label for="nama_kategori" class="block text-sm font-medium text-gray-700 mb-1">Nama Kategori *</label>
            <input type="text" id="nama_kategori" name="nama_kategori" required minlength="2" maxlength="100"
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]">
          </div>
          
          <div class="pt-4 flex justify-end space-x-3">
            <button type="button" id="btn-cancel-form" class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[var(--color-primary)]">
              Batal
            </button>
            <button type="submit" id="btn-save" class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[var(--color-primary)]">
              Simpan
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Delete Dialog -->
  <div id="modal-delete" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm mx-4 transform translate-y-4 transition-transform duration-300" id="modal-delete-content">
      <div class="p-6">
        <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-100 rounded-full">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <h3 class="mb-2 text-lg font-normal text-center text-gray-900">Konfirmasi Hapus</h3>
        <p class="mb-6 text-sm text-center text-gray-500">Hapus kategori <strong id="delete-target-name" class="text-gray-900"></strong>?</p>
        <div class="flex justify-center gap-3">
          <button id="btn-cancel-delete" type="button" class="text-gray-500 bg-white hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-gray-200 rounded-lg text-sm font-medium px-5 py-2.5">Batal</button>
          <button id="btn-confirm-delete" type="button" class="text-white bg-red-600 hover:bg-red-800 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5">Hapus</button>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  let currentDeleteId: string | null = null;
  let isEditing = false;
  
  const modalForm = document.getElementById('modal-form');
  const modalFormContent = document.getElementById('modal-form-content');
  const modalTitle = document.getElementById('modal-title');
  const btnAdd = document.getElementById('btn-add-kategori');
  const btnCloseForm = document.getElementById('btn-close-modal');
  const btnCancelForm = document.getElementById('btn-cancel-form');
  const form = document.getElementById('kategori-form') as HTMLFormElement;
  const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
  
  const modalDelete = document.getElementById('modal-delete');
  const modalDeleteContent = document.getElementById('modal-delete-content');
  const btnCancelDelete = document.getElementById('btn-cancel-delete');
  const btnConfirmDelete = document.getElementById('btn-confirm-delete');
  const deleteTargetName = document.getElementById('delete-target-name');

  const openFormModal = (edit = false, id = '', name = '') => {
    isEditing = edit;
    form.reset();
    
    if (modalTitle) modalTitle.textContent = edit ? "Edit Kategori" : "Tambah Kategori";
    
    (document.getElementById('form-id') as HTMLInputElement).value = id;
    if (edit) {
      (document.getElementById('nama_kategori') as HTMLInputElement).value = name;
    }

    modalForm?.classList.remove('hidden');
    setTimeout(() => {
      modalForm?.classList.remove('opacity-0');
      modalFormContent?.classList.remove('translate-y-4');
    }, 10);
  };

  const closeFormModal = () => {
    modalForm?.classList.add('opacity-0');
    modalFormContent?.classList.add('translate-y-4');
    setTimeout(() => modalForm?.classList.add('hidden'), 300);
  };

  const openDeleteModal = (id: string, name: string) => {
    currentDeleteId = id;
    if (deleteTargetName) deleteTargetName.textContent = name;
    
    modalDelete?.classList.remove('hidden');
    setTimeout(() => {
      modalDelete?.classList.remove('opacity-0');
      modalDeleteContent?.classList.remove('translate-y-4');
    }, 10);
  };

  const closeDeleteModal = () => {
    currentDeleteId = null;
    modalDelete?.classList.add('opacity-0');
    modalDeleteContent?.classList.add('translate-y-4');
    setTimeout(() => modalDelete?.classList.add('hidden'), 300);
  };

  btnAdd?.addEventListener('click', () => openFormModal(false));
  btnCloseForm?.addEventListener('click', closeFormModal);
  btnCancelForm?.addEventListener('click', closeFormModal);
  btnCancelDelete?.addEventListener('click', closeDeleteModal);

  document.querySelectorAll('.btn-edit').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLElement;
      openFormModal(true, el.dataset.id, el.dataset.nama);
    });
  });

  document.querySelectorAll('.btn-delete').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLElement;
      if (parseInt(el.dataset.count || '0') > 0) {
        window.showToast('Kategori tidak dapat dihapus karena masih digunakan oleh barang', 'error');
        return;
      }
      openDeleteModal(el.dataset.id!, el.dataset.nama!);
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btnSave.disabled = true;
    btnSave.textContent = 'Menyimpan...';

    const formData = new FormData(form);
    const id = formData.get('id') as string;
    const payload = { nama_kategori: formData.get('nama_kategori') };

    try {
      if (isEditing && id) {
        const { error } = await supabase.from('kategori').update(payload).eq('id', id);
        if (error) throw error;
        window.showToast('Kategori berhasil diupdate');
      } else {
        const { error } = await supabase.from('kategori').insert([payload]);
        if (error) throw error;
        window.showToast('Kategori baru berhasil ditambahkan');
      }
      
      closeFormModal();
      setTimeout(() => window.location.reload(), 500); // Reload to reflect changes server-side
    } catch (err: any) {
      // Supabase unique constraint error: 23505
      if (err.code === '23505') {
        window.showToast('Nama kategori sudah digunakan', 'error');
      } else {
        window.showToast(err.message || 'Gagal menyimpan kategori', 'error');
      }
    } finally {
      btnSave.disabled = false;
      btnSave.textContent = 'Simpan';
    }
  });

  btnConfirmDelete?.addEventListener('click', async () => {
    if (!currentDeleteId) return;
    
    const btn = btnConfirmDelete as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Menghapus...';

    try {
      const { error } = await supabase.from('kategori').delete().eq('id', currentDeleteId);
      if (error) throw error;
      
      window.showToast('Kategori berhasil dihapus');
      closeDeleteModal();
      setTimeout(() => window.location.reload(), 500);
    } catch (err: any) {
      window.showToast(err.message || 'Gagal menghapus kategori', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Hapus';
    }
  });
</script>
