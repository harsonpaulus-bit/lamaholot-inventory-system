---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/shared/Card.astro';
import Badge from '../components/shared/Badge.astro';
import { createSSRClient } from '../lib/supabase';

const token = Astro.cookies.get('sb-access-token')?.value;
const supabase = createSSRClient(token);
let stats = { total: 0, baik: 0, rusakRingan: 0, rusakBerat: 0 };
let recentItems: any[] = [];
let categoryChartData: { labels: string[], values: number[] } = { labels: [], values: [] };
let trendChartData: { labels: string[], values: number[] } = { labels: [], values: [] };
let error = null;

try {
  // Fetch all necessary data for stats and charts
  const [
    { count: totalCount },
    { count: baikCount },
    { count: rusakRinganCount },
    { count: rusakBeratCount },
    { data: recent },
    { data: allBarang }
  ] = await Promise.all([
    supabase.from('barang').select('*', { count: 'exact', head: true }),
    supabase.from('barang').select('*', { count: 'exact', head: true }).eq('kondisi', 'Baik'),
    supabase.from('barang').select('*', { count: 'exact', head: true }).eq('kondisi', 'Rusak Ringan'),
    supabase.from('barang').select('*', { count: 'exact', head: true }).eq('kondisi', 'Rusak Berat'),
    supabase.from('barang').select('*, kategori(nama_kategori)').order('created_at', { ascending: false }).limit(5),
    supabase.from('barang').select('created_at, kategori(nama_kategori)')
  ]);

  stats = {
    total: totalCount || 0,
    baik: baikCount || 0,
    rusakRingan: rusakRinganCount || 0,
    rusakBerat: rusakBeratCount || 0,
  };
  recentItems = recent || [];

  // 1. Calculate Category Distribution
  const catMap: Record<string, number> = {};
  allBarang?.forEach(b => {
    const name = b.kategori?.nama_kategori || 'Tanpa Kategori';
    catMap[name] = (catMap[name] || 0) + 1;
  });
  categoryChartData = {
    labels: Object.keys(catMap),
    values: Object.values(catMap)
  };

  // 2. Calculate Monthly Trend (Last 6 Months)
  const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
  const trendMap: Record<string, number> = {};
  
  // Initialize last 6 months with 0
  const now = new Date();
  for (let i = 5; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    const key = `${monthNames[d.getMonth()]} ${d.getFullYear()}`;
    trendMap[key] = 0;
  }

  allBarang?.forEach(b => {
    const d = new Date(b.created_at);
    const key = `${monthNames[d.getMonth()]} ${d.getFullYear()}`;
    if (trendMap[key] !== undefined) {
      trendMap[key]++;
    }
  });

  // Convert map to cumulative growth or just monthly adds? 
  // User image looks like cumulative or wavy growth. Let's do cumulative for "Total Aset" feel.
  let runningTotal = stats.total - (allBarang?.filter(b => new Date(b.created_at) > new Date(now.getFullYear(), now.getMonth() - 5, 1)).length || 0);
  const trendLabels = Object.keys(trendMap);
  const trendValues = trendLabels.map(label => {
    runningTotal += trendMap[label];
    return runningTotal;
  });

  trendChartData = {
    labels: trendLabels,
    values: trendValues
  };

} catch (e: any) {
  error = "Gagal memuat data real. Menggunakan data simulasi.";
  stats = { total: 234, baik: 180, rusakRingan: 42, rusakBerat: 12 };
  recentItems = [
    { id: '1', nama_barang: 'Meja Guru', kondisi: 'Baik', kategori: { nama_kategori: 'Mebeler' }, created_at: new Date().toISOString() },
    { id: '2', nama_barang: 'Laptop ASUS', kondisi: 'Rusak Ringan', kategori: { nama_kategori: 'Elektronik' }, created_at: new Date().toISOString() },
  ];
  categoryChartData = { labels: ['Mebeler', 'Elektronik', 'Alat Tulis'], values: [120, 80, 34] };
  trendChartData = { labels: ['Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt'], values: [180, 200, 210, 225, 230, 234] };
}

const pct = (count: number) => stats.total > 0 ? Math.round((count / stats.total) * 100) : 0;
---

<MainLayout title="Dashboard">
  <!-- Quick Actions Row -->
  <div class="flex flex-wrap gap-4 mb-8">
    <a href="/barang?add=true" class="flex items-center gap-2.5 px-5 py-3 bg-[#354ae6] text-white rounded-2xl font-bold transition-all hover:bg-[#283593] shadow-lg shadow-indigo-500/20 active:scale-95 group">
      <div class="p-1 bg-white/20 rounded-lg group-hover:scale-110 transition-transform">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
      </div>
      <span class="text-sm tracking-wide">Tambah Barang</span>
    </a>
    
    <a href="/kategori?add=true" class="flex items-center gap-2.5 px-5 py-3 bg-white text-surface-700 border border-surface-200 rounded-2xl font-bold transition-all hover:bg-surface-50 shadow-sm active:scale-95 group">
      <div class="p-1 bg-surface-100 rounded-lg group-hover:scale-110 transition-transform">
        <svg class="w-4 h-4 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
      </div>
      <span class="text-sm tracking-wide text-surface-600">Tambah Kategori</span>
    </a>
  </div>

  <!-- Row 1: KPI Cards (4 columns) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Total Barang</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.total}</h2>
          <span class="text-[10px] font-bold text-green-500 bg-green-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"></path></svg>
            Up
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Statistik waktu nyata</p>
    </div>

    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Kondisi Baik</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.baik}</h2>
          <span class="text-[10px] font-bold text-green-500 bg-green-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            {pct(stats.baik)}%
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Kondisi operasional</p>
    </div>

    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Rusak Ringan</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.rusakRingan}</h2>
          <span class="text-[10px] font-bold text-yellow-500 bg-yellow-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            {pct(stats.rusakRingan)}%
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Perlu pemeliharaan</p>
    </div>

    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Rusak Berat</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.rusakBerat}</h2>
          <span class="text-[10px] font-bold text-red-500 bg-red-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            {pct(stats.rusakBerat)}%
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Segera diganti</p>
    </div>
  </div>

  <!-- Row 2: Large Line Chart & Side Panel -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 glass-card p-8 flex flex-col min-h-[420px]">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h3 class="text-base font-bold text-surface-900 tracking-tight">Tren Inventaris</h3>
          <p class="text-2xl font-extrabold text-surface-900 mt-1 tracking-tight">Total Aset: {stats.total}</p>
        </div>
        <div class="text-[11px] font-bold bg-surface-50 border border-surface-100 rounded-lg px-3 py-1.5 text-surface-500">
          6 Bulan Terakhir
        </div>
      </div>
      <div class="flex-1 w-full relative">
        <canvas id="lineChart"></canvas>
      </div>
    </div>

    <div class="flex flex-col gap-6">
      <!-- Top Items (Horizontal Bar) -->
      <div class="glass-card p-6 flex-1">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-sm font-bold text-surface-900 tracking-tight">Kondisi Dominan</h3>
        </div>
        <div class="space-y-5">
           <div class="space-y-1.5">
             <div class="flex justify-between items-center text-[11px] font-bold text-surface-500 uppercase tracking-wide">
               <span>Baik</span>
               <span>{stats.baik} Unit</span>
             </div>
             <div class="h-2 w-full bg-surface-100 rounded-full overflow-hidden">
                <div class="h-full bg-primary-600 rounded-full transition-all duration-1000" style={`width: ${pct(stats.baik)}%`}></div>
             </div>
           </div>
           <div class="space-y-1.5">
             <div class="flex justify-between items-center text-[11px] font-bold text-surface-500 uppercase tracking-wide">
               <span>Rusak Ringan</span>
               <span>{stats.rusakRingan} Unit</span>
             </div>
             <div class="h-2 w-full bg-surface-100 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-400 rounded-full transition-all duration-1000" style={`width: ${pct(stats.rusakRingan)}%`}></div>
             </div>
           </div>
           <div class="space-y-1.5">
             <div class="flex justify-between items-center text-[11px] font-bold text-surface-500 uppercase tracking-wide">
               <span>Rusak Berat</span>
               <span>{stats.rusakBerat} Unit</span>
             </div>
             <div class="h-2 w-full bg-surface-100 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-200 rounded-full transition-all duration-1000" style={`width: ${pct(stats.rusakBerat)}%`}></div>
             </div>
           </div>
        </div>
      </div>

      <!-- Recent Items -->
      <div class="glass-card p-6 flex-1">
        <div class="flex justify-between items-center mb-4">
          <div>
            <h3 class="text-sm font-bold text-surface-900 tracking-tight">Update Terakhir</h3>
            <p class="text-[11px] font-medium text-surface-400 mt-0.5">{recentItems.length} barang baru ditambahkan</p>
          </div>
        </div>
        <div class="space-y-3">
          {recentItems.slice(0, 4).map((item) => (
            <div class="flex items-center justify-between group cursor-default">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-surface-50 flex items-center justify-center text-xs font-bold text-surface-600 group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors">
                  {item.nama_barang[0]}
                </div>
                <div>
                   <p class="text-xs font-bold text-surface-800 tracking-tight">{item.nama_barang}</p>
                   <p class="text-[10px] font-medium text-surface-400 uppercase">{item.kategori?.nama_kategori || 'N/A'}</p>
                </div>
              </div>
              <div class={`w-2 h-2 rounded-full ${item.kondisi === 'Baik' ? 'bg-green-500' : 'bg-red-500'}`}></div>
            </div>
          ))}
          <a href="/barang" class="block w-full text-center py-2 mt-2 bg-primary-600 text-white rounded-lg text-xs font-bold shadow-md shadow-primary-500/10 hover:bg-primary-700 transition-all">View All</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Row 3: Smaller Charts (2 columns now) -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
     <div class="glass-card p-6 min-h-[350px] flex flex-col">
       <div class="flex justify-between items-center mb-6">
         <h3 class="text-sm font-bold text-surface-900 tracking-tight">Barang Per Kategori</h3>
       </div>
       <div class="flex-1 w-full relative">
         <canvas id="categoryChart"></canvas>
       </div>
     </div>

     <div class="glass-card p-6 min-h-[350px] flex flex-col">
       <div class="flex justify-between items-center mb-6">
         <h3 class="text-sm font-bold text-surface-900 tracking-tight">Status Kondisi Aset</h3>
       </div>
       <div class="flex-1 w-full relative">
         <canvas id="conditionPieChart"></canvas>
       </div>
     </div>
  </div>
</MainLayout>

<script define:vars={{ stats, categoryChartData, trendChartData }}>
  const loadScript = document.createElement("script");
  loadScript.src = "https://cdn.jsdelivr.net/npm/chart.js";
  loadScript.onload = () => {
    // Shared chart options
    const commonOptions = {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#0f172a',
          padding: 12,
          cornerRadius: 8,
          titleFont: { family: "'Plus Jakarta Sans'", size: 12, weight: 'bold' },
          bodyFont: { family: "'Plus Jakarta Sans'", size: 12 },
          boxPadding: 4
        }
      }
    };

    // 1. Line Chart (Trend)
    new Chart(document.getElementById('lineChart'), {
      type: 'line',
      data: {
        labels: trendChartData.labels,
        datasets: [{
          data: trendChartData.values,
          borderColor: '#354ae6',
          borderWidth: 3,
          tension: 0.4,
          fill: true,
          backgroundColor: (context) => {
            const chart = context.chart;
            const {ctx, canvas, chartArea} = chart;
            if (!chartArea) return null;
            const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
            gradient.addColorStop(0, 'rgba(53, 74, 230, 0)');
            gradient.addColorStop(1, 'rgba(53, 74, 230, 0.15)');
            return gradient;
          },
          pointRadius: 4,
          pointBackgroundColor: '#354ae6',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          pointHoverRadius: 6
        }]
      },
      options: {
        ...commonOptions,
        scales: {
          y: {
            grid: { display: true, color: '#f1f5f9', drawBorder: false },
            ticks: { color: '#94a3b8', font: { size: 10, weight: '600' }, padding: 10 }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#94a3b8', font: { size: 10, weight: '600' }, padding: 10 }
          }
        }
      }
    });

    // 2. Category Bar Chart
    new Chart(document.getElementById('categoryChart'), {
      type: 'bar',
      data: {
        labels: categoryChartData.labels,
        datasets: [{
          data: categoryChartData.values,
          backgroundColor: '#e0e7ff',
          hoverBackgroundColor: '#354ae6',
          borderRadius: 8,
          barThickness: 32
        }]
      },
      options: {
        ...commonOptions,
        scales: {
          y: {
            grid: { display: true, color: '#f1f5f9', drawBorder: false },
            ticks: { color: '#94a3b8', font: { size: 10, weight: '600' } }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#94a3b8', font: { size: 10, weight: '600' } }
          }
        }
      }
    });

    // 3. Condition Pie Chart
    new Chart(document.getElementById('conditionPieChart'), {
      type: 'pie',
      data: {
        labels: ['Baik', 'Rusak Ringan', 'Rusak Berat'],
        datasets: [{
          data: [stats.baik, stats.rusakRingan, stats.rusakBerat],
          backgroundColor: ['#0d9488', '#f59e0b', '#ef4444'],
          borderWidth: 0
        }]
      },
      options: {
        ...commonOptions,
        plugins: {
           ...commonOptions.plugins,
           legend: { 
             display: true, 
             position: 'bottom', 
             labels: { 
               usePointStyle: true, 
               padding: 20,
               font: { size: 11, weight: '700', family: "'Plus Jakarta Sans'" },
               generateLabels: (chart) => {
                 const data = chart.data;
                 const total = data.datasets[0].data.reduce((acc, val) => acc + val, 0);
                 return data.labels.map((label, i) => ({
                   text: `${label} (${total > 0 ? Math.round((data.datasets[0].data[i] / total) * 100) : 0}%)`,
                   fillStyle: data.datasets[0].backgroundColor[i],
                   strokeStyle: data.datasets[0].backgroundColor[i],
                   lineWidth: 0,
                   index: i
                 }));
               }
             } 
           },
           tooltip: {
             enabled: true,
             callbacks: {
               label: (context) => {
                 const label = context.label || '';
                 const value = context.parsed || 0;
                 const total = context.dataset.data.reduce((acc, val) => acc + (val || 0), 0);
                 const percentage = total > 0 ? Math.round((value / total) * 100) : 0;
                 return `${label}: ${value} Unit (${percentage}%)`;
               }
             }
           }
        }
      }
    });
  };
  document.head.appendChild(loadScript);
</script>

