---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/shared/Card.astro';
import Badge from '../components/shared/Badge.astro';
import { createSSRClient } from '../lib/supabase';

const token = Astro.cookies.get('sb-access-token')?.value;
const supabase = createSSRClient(token);
let stats = { total: 0, baik: 0, rusakRingan: 0, rusakBerat: 0 };
let recentItems: any[] = [];
let error = null;

try {
  const [
    { count: totalCount },
    { count: baikCount },
    { count: rusakRinganCount },
    { count: rusakBeratCount },
    { data: recent }
  ] = await Promise.all([
    supabase.from('barang').select('*', { count: 'exact', head: true }),
    supabase.from('barang').select('*', { count: 'exact', head: true }).eq('kondisi', 'Baik'),
    supabase.from('barang').select('*', { count: 'exact', head: true }).eq('kondisi', 'Rusak Ringan'),
    supabase.from('barang').select('*', { count: 'exact', head: true }).eq('kondisi', 'Rusak Berat'),
    supabase.from('barang').select('*, kategori(nama_kategori)').order('created_at', { ascending: false }).limit(5)
  ]);

  stats = {
    total: totalCount || 0,
    baik: baikCount || 0,
    rusakRingan: rusakRinganCount || 0,
    rusakBerat: rusakBeratCount || 0,
  };
  recentItems = recent || [];
} catch (e: any) {
  error = "Koneksi database belum terkonfigurasi. Tampilan menggunakan data simulasi.";
  stats = { total: 234, baik: 180, rusakRingan: 42, rusakBerat: 12 };
  recentItems = [
    { id: '1', nama_barang: 'Meja Guru', kondisi: 'Baik', kategori: { nama_kategori: 'Mebeler' }, created_at: new Date().toISOString() },
    { id: '2', nama_barang: 'Laptop ASUS', kondisi: 'Rusak Ringan', kategori: { nama_kategori: 'Elektronik' }, created_at: new Date().toISOString() },
  ];
}

const pct = (count: number) => stats.total > 0 ? Math.round((count / stats.total) * 100) : 0;
---

<MainLayout title="Dashboard">
  <!-- Row 1: KPI Cards (4 columns) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Total Barang</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.total}</h2>
          <span class="text-[10px] font-bold text-green-500 bg-green-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"></path></svg>
            10%
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Compared to Last Month</p>
    </div>

    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Kondisi Baik</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.baik}</h2>
          <span class="text-[10px] font-bold text-green-500 bg-green-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"></path></svg>
            5%
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Compared to Last Month</p>
    </div>

    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Rusak Ringan</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.rusakRingan}</h2>
          <span class="text-[10px] font-bold text-red-500 bg-red-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
            10%
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Compared to Last Month</p>
    </div>

    <div class="glass-card p-6 flex flex-col justify-between min-h-[140px]">
      <div>
        <p class="text-[11px] font-bold text-surface-400 uppercase tracking-widest mb-2">Rusak Berat</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-3xl font-extrabold text-surface-900 tracking-tight">{stats.rusakBerat}</h2>
          <span class="text-[10px] font-bold text-green-500 bg-green-50 px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"></path></svg>
            2%
          </span>
        </div>
      </div>
      <p class="text-[11px] text-surface-400 font-medium mt-4">Compared to Last Month</p>
    </div>
  </div>

  <!-- Row 2: Large Line Chart & Side Panel -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 glass-card p-8 flex flex-col min-h-[420px]">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h3 class="text-base font-bold text-surface-900 tracking-tight">Tren Inventaris</h3>
          <p class="text-2xl font-extrabold text-surface-900 mt-1 tracking-tight">Total Aset: {stats.total}</p>
        </div>
        <select class="text-[11px] font-bold bg-surface-50 border border-surface-100 rounded-lg px-3 py-1.5 text-surface-500 outline-none">
          <option>Month</option>
        </select>
      </div>
      <div class="flex-1 w-full relative">
        <canvas id="lineChart"></canvas>
      </div>
    </div>

    <div class="flex flex-col gap-6">
      <!-- Top Items (Horizontal Bar) -->
      <div class="glass-card p-6 flex-1">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-sm font-bold text-surface-900 tracking-tight">Kondisi Dominan</h3>
          <select class="text-[11px] font-bold bg-surface-50 border border-surface-100 rounded-lg px-2 py-1 text-surface-400 outline-none">
            <option>Month</option>
          </select>
        </div>
        <div class="space-y-5">
           <div class="space-y-1.5">
             <div class="flex justify-between items-center text-[11px] font-bold text-surface-500 uppercase tracking-wide">
               <span>Baik</span>
               <span>{stats.baik} Unit</span>
             </div>
             <div class="h-2 w-full bg-surface-100 rounded-full overflow-hidden">
                <div class="h-full bg-primary-600 rounded-full transition-all duration-1000" style={`width: ${pct(stats.baik)}%`}></div>
             </div>
           </div>
           <div class="space-y-1.5">
             <div class="flex justify-between items-center text-[11px] font-bold text-surface-500 uppercase tracking-wide">
               <span>Rusak Ringan</span>
               <span>{stats.rusakRingan} Unit</span>
             </div>
             <div class="h-2 w-full bg-surface-100 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-400 rounded-full transition-all duration-1000" style={`width: ${pct(stats.rusakRingan)}%`}></div>
             </div>
           </div>
           <div class="space-y-1.5">
             <div class="flex justify-between items-center text-[11px] font-bold text-surface-500 uppercase tracking-wide">
               <span>Rusak Berat</span>
               <span>{stats.rusakBerat} Unit</span>
             </div>
             <div class="h-2 w-full bg-surface-100 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-200 rounded-full transition-all duration-1000" style={`width: ${pct(stats.rusakBerat)}%`}></div>
             </div>
           </div>
        </div>
      </div>

      <!-- Low Attention Items -->
      <div class="glass-card p-6 flex-1">
        <div class="flex justify-between items-center mb-4">
          <div>
            <h3 class="text-sm font-bold text-surface-900 tracking-tight">Update Terakhir</h3>
            <p class="text-[11px] font-medium text-surface-400 mt-0.5">{recentItems.length} barang baru ditambahkan</p>
          </div>
        </div>
        <div class="space-y-3">
          {recentItems.slice(0, 4).map((item) => (
            <div class="flex items-center justify-between group cursor-default">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-surface-50 flex items-center justify-center text-xs font-bold text-surface-600 group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors">
                  {item.nama_barang[0]}
                </div>
                <div>
                   <p class="text-xs font-bold text-surface-800 tracking-tight">{item.nama_barang}</p>
                   <p class="text-[10px] font-medium text-surface-400 uppercase">{item.kategori?.nama_kategori || 'N/A'}</p>
                </div>
              </div>
              <div class={`w-2 h-2 rounded-full ${item.kondisi === 'Baik' ? 'bg-green-500' : 'bg-red-500'}`}></div>
            </div>
          ))}
          <a href="/barang" class="block w-full text-center py-2 mt-2 bg-primary-600 text-white rounded-lg text-xs font-bold shadow-md shadow-primary-500/10 hover:bg-primary-700 transition-all">View All</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Row 3: Smaller Charts (3 columns) -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
     <div class="glass-card p-6 min-h-[300px] flex flex-col">
       <div class="flex justify-between items-center mb-6">
         <h3 class="text-sm font-bold text-surface-900 tracking-tight">Barang Per Kategori</h3>
         <select class="text-[11px] font-bold bg-surface-50 border border-surface-100 rounded-lg px-2 py-1 text-surface-400 outline-none">
            <option>Month</option>
          </select>
       </div>
       <div class="flex-1 w-full relative">
         <canvas id="categoryChart"></canvas>
       </div>
     </div>

     <div class="glass-card p-6 min-h-[300px] flex flex-col">
       <div class="flex justify-between items-center mb-6">
         <h3 class="text-sm font-bold text-surface-900 tracking-tight">Kondisi Aset</h3>
       </div>
       <div class="flex-1 w-full relative">
         <canvas id="conditionPieChart"></canvas>
       </div>
     </div>

     <div class="glass-card p-6 min-h-[300px] flex flex-col">
       <div class="flex justify-between items-center mb-6">
         <h3 class="text-sm font-bold text-surface-900 tracking-tight">Proporsi Pengguna</h3>
       </div>
       <div class="flex-1 w-full relative">
         <canvas id="userDonutChart"></canvas>
       </div>
     </div>
  </div>
</MainLayout>

<script define:vars={{ stats }}>
  const loadScript = document.createElement("script");
  loadScript.src = "https://cdn.jsdelivr.net/npm/chart.js";
  loadScript.onload = () => {
    // Shared chart options
    const commonOptions = {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#0f172a',
          padding: 12,
          cornerRadius: 8,
          titleFont: { family: "'Plus Jakarta Sans'", size: 12, weight: 'bold' },
          bodyFont: { family: "'Plus Jakarta Sans'", size: 12 },
          boxPadding: 4
        }
      }
    };

    // 1. Line Chart
    new Chart(document.getElementById('lineChart'), {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct'],
        datasets: [{
          data: [18, 28, 22, 35, 25, 38, 48, 42, 55, 48],
          borderColor: '#354ae6',
          borderWidth: 3,
          tension: 0.4,
          fill: true,
          backgroundColor: (context) => {
            const chart = context.chart;
            const {ctx, canvas, chartArea} = chart;
            if (!chartArea) return null;
            const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
            gradient.addColorStop(0, 'rgba(53, 74, 230, 0)');
            gradient.addColorStop(1, 'rgba(53, 74, 230, 0.15)');
            return gradient;
          },
          pointRadius: 0,
          pointHoverRadius: 6,
          pointHoverBackgroundColor: '#354ae6',
          pointHoverBorderColor: '#fff',
          pointHoverBorderWidth: 3
        }]
      },
      options: {
        ...commonOptions,
        scales: {
          y: {
            grid: { display: true, color: '#f1f5f9', drawBorder: false },
            ticks: { color: '#94a3b8', font: { size: 10, weight: '600' }, padding: 10 }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#94a3b8', font: { size: 10, weight: '600' }, padding: 10 }
          }
        }
      }
    });

    // 2. Category Bar Chart
    new Chart(document.getElementById('categoryChart'), {
      type: 'bar',
      data: {
        labels: ['Mar', 'May', 'Jun', 'Jul', 'Aug', 'Sep'],
        datasets: [{
          data: [28, 18, 14, 25, 42, 28],
          backgroundColor: (context) => context.index === 4 ? '#354ae6' : '#e0e7ff',
          borderRadius: 8,
          barThickness: 24
        }]
      },
      options: {
        ...commonOptions,
        scales: {
          y: {
            grid: { display: true, color: '#f1f5f9', drawBorder: false },
            ticks: { display: false }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#94a3b8', font: { size: 10, weight: '600' } }
          }
        }
      }
    });

    // 3. Condition Pie Chart
    new Chart(document.getElementById('conditionPieChart'), {
      type: 'pie',
      data: {
        labels: ['Baik', 'Rusak', 'Lainnya'],
        datasets: [{
          data: [45, 45, 10],
          backgroundColor: ['#0d9488', '#f59e0b', '#ef4444'],
          borderWidth: 0
        }]
      },
      options: {
        ...commonOptions,
        plugins: {
           ...commonOptions.plugins,
           legend: { display: true, position: 'bottom', labels: { usePointStyle: true, font: { size: 10, weight: '600' } } }
        }
      }
    });

    // 4. User Donut Chart
    new Chart(document.getElementById('userDonutChart'), {
      type: 'doughnut',
      data: {
        labels: ['Customers', 'Employees', 'Suppliers'],
        datasets: [{
          data: [52, 28, 20],
          backgroundColor: ['#354ae6', '#34d399', '#fb923c'],
          borderWidth: 0,
          cutout: '70%'
        }]
      },
      options: {
        ...commonOptions,
        plugins: {
           ...commonOptions.plugins,
           legend: { display: true, position: 'bottom', labels: { usePointStyle: true, font: { size: 10, weight: '600' } } }
        }
      }
    });
  };
  document.head.appendChild(loadScript);
</script>
